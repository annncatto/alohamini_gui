#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$BIN_DIR/../ssh_common.sh"

REAL_SCP="${ALOHAMINI_REAL_SCP:-/usr/bin/scp}"
if [[ ! -x "$REAL_SCP" && -x /bin/scp ]]; then
  REAL_SCP="/bin/scp"
fi
if [[ ! -x "$REAL_SCP" ]]; then
  echo "OpenSSH scp client is not installed." >&2
  exit 127
fi

if [[ -n "$PI_HOST" && -S "$SSH_CONTROL_PATH" ]] && \
  "$REAL_SSH" -S "$SSH_CONTROL_PATH" -O check "$SSH_TARGET" >/dev/null 2>&1; then
  exec "$REAL_SCP" -o ControlPath="$SSH_CONTROL_PATH" -o ControlMaster=no "$@"
fi

exec "$REAL_SCP" "$@"
